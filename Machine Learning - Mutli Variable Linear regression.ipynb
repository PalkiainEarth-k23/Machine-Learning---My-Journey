import pandas as pd
import sklearn.linear_model as sk
df = pd.read_csv("C:/Users/srini/Downloads/hiring.csv")
df.columns = df.columns.str.strip() 
df.experience = df.experience.replace({'five':5, 'two':2, 'seven':7, 'three':3, 'ten':10, 'eleven':11}).fillna(0)
median_experience = df.experience.median()
median_test_scores = df.test_score.median()
Output = df['salary($)']
df.experience = df.experience.fillna(median_experience)
df.test_score = df.test_score.fillna(median_test_scores)
reg = sk.LinearRegression()
reg.fit(df[['test_score', 'experience', 'interview_score']], Output)
